NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgres://saashakti:saashakti@localhost:5432/saashakti
REDIS_URL=redis://localhost:6379

OTP_MODE=mock
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=30
OTP_HOURLY_LIMIT_PER_MOBILE=5
OTP_HOURLY_LIMIT_PER_IP=20

SESSION_TTL_SECONDS=86400

CORS_ORIGINS=http://localhost:5173,http://localhost:5174

DASHBOARD_CACHE_TTL_SECONDS=15

# Optional: override where infra/sql migrations are read from.
# Defaults to the monorepo infra/sql when running from source;
# set to /app/infra/sql in container deployments.
# MIGRATIONS_DIR=/app/infra/sql

# Aadhaar provider: mock (default, deterministic fake data) | karza | uidai
AADHAAR_PROVIDER=mock
# Karza (REST vendor): obtain from https://karza.in
# AADHAAR_KARZA_API_KEY=your-karza-api-key
# AADHAAR_KARZA_BASE_URL=https://api.karza.in
# UIDAI direct (SOAP, requires AUA/KUA license + compliance audit):
# AADHAAR_AUA_CODE=your-10-char-aua-code
# AADHAAR_AUA_LICENSE_KEY=base64-license-key
# AADHAAR_ASA_API_URL=https://asa-provider-url
