NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgres://saashakti:saashakti@localhost:5432/saashakti
REDIS_URL=redis://localhost:6379

OTP_MODE=mock
