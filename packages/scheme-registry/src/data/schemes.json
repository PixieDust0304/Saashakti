          "labelEn": "Marital status: married/widow/divorced/deserted"
        },
        {
          "field": "stateDomicile",
          "operator": "eq",
          "value": "Chhattisgarh",
          "labelHi": "छत्तीसगढ़ निवासी",
          "labelEn": "Chhattisgarh resident"
        },
        {
          "field": "hasBankAccount",
          "operator": "truthy",
          "labelHi": "बैंक खाता",
          "labelEn": "Has bank account"
        }
      ],
      "exclusions": [
